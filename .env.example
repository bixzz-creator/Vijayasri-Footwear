# Copy to .env and fill in your Supabase project values.
# The anon key is safe to expose in the storefront (client-side).

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Gemini API key for CLI photo rename (npm run rename-slippers:ai -- --engine gemini)
GEMINI_API_KEY=AIza-your-key-here

# Optional: OpenRouter key (if not using Gemini direct)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
