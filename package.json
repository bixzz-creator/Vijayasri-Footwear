{
  "name": "vijayasri-footwear-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "build:storefront": "npm run build --workspace=@vijayasri/storefront",
    "build:admin": "npm run build --workspace=@vijayasri/admin",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "prebuild": "node scripts/generate-sitemap.mjs || echo 'Sitemap generation skipped'",
    "deploy": "npx wrangler pages deploy apps/storefront/dist --project-name=vijayasri-footwear",
    "deploy:storefront": "npx wrangler pages deploy apps/storefront/dist --project-name=vijayasri-footwear",
    "deploy:admin": "npx wrangler pages deploy apps/admin/dist --project-name=vijayasri-admin",
    "tsc": "npm run tsc --workspaces --if-present",
    "rename-slippers": "node scripts/rename-slipper-photos.mjs",
    "rename-slippers:dry": "node scripts/rename-slipper-photos.mjs --dry-run",
    "rename-slippers:ai": "node scripts/rename-slipper-photos.mjs --engine ocrspace",
    "rename-slippers:ai:dry": "node scripts/rename-slipper-photos.mjs --engine ocrspace --dry-run"
  },
  "devDependencies": {
    "sharp": "^0.35.3",
    "tesseract.js": "^7.0.0",
    "tsx": "^4.23.0"
  }
}
